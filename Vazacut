            <div><strong>1080p Full HD</strong><br><span>Grátis • H.264 • até 60fps</span></div>
          </label>
          <label class="radio-card locked" id="card4k">
            <input type="radio" name="res" value="4k" id="res4k" disabled>
            <div><strong>4K Ultra HD</strong><br><span>PRO • H.265 • qualidade máxima</span></div>
          </label>
        </div>
        <button class="btn-primary" id="exportBtn" style="width:100%;padding:14px;font-size:15px">Exportar MP4</button>
        <div class="progress-wrap" id="progressWrap">
