<script>
const PRO_CODES = ["VAZA-GS-2026-001","VAZA-GS-2026-ABC"];
const video = document.getElementById('preview');
const videoInput = document.getElementById('videoInput');
const fileName = document.getElementById('fileName');
const dropHint = document.getElementById('dropHint');
const previewWrap = document.getElementById('previewWrap');
const subtitleOverlay = document.getElementById('subtitleOverlay');

const startTime = document.getElementById('startTime');
const endTime = document.getElementById('endTime');

const brightness = document.getElementById('brightness');
const contrast = document.getElementById('contrast');
const saturation = document.getElementById('saturation');
const bVal = document.getElementById('bVal');
const cVal = document.getElementById('cVal');
const sVal = document.getElementById('sVal');

const srtInput = document.getElementById('srtInput');
const burnToggle = document.getElementById('burnToggle');

const proStatus = document.getElementById('proStatus');
const codeInput = document.getElementById('codeInput');
const activateBtn = document.getElementById('activateBtn');

const res1080 = document.getElementById('res1080');
const res4k = document.getElementById('res4k');
const card4k = document.getElementById('card4k');
const exportBtn = document.getElementById('exportBtn');
const progressWrap = document.getElementById('progressWrap');
const progressFill = document.getElementById('progressFill');
const progressText = document.getElementById('progressText');

let subtitles = [];
let isPro = localStorage.getItem('vazacut_pro') === 'true';

// Tabs
document.querySelectorAll('.tabs button').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tabs button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
  });
});

// File load
function loadFile(file){
  if(!file || !file.type.startsWith('video/')){showToast('Selecione um vídeo válido',true);return;}
  const url = URL.createObjectURL(file);
  video.src = url;
  fileName.textContent = file.name;
  dropHint.style.display='none';
  video.load();
}
videoInput.addEventListener('change',e=>loadFile(e.target.files[0]));
previewWrap.addEventListener('dragover',e=>{e.preventDefault();previewWrap.style.borderColor='var(--accent)'});
previewWrap.addEventListener('dragleave',()=>{previewWrap.style.borderColor='var(--border)'});
previewWrap.addEventListener('drop',e=>{e.preventDefault();previewWrap.style.borderColor='var(--border)';loadFile(e.dataTransfer.files[0])});

video.addEventListener('loadedmetadata',()=>{
  endTime.value = video.duration.toFixed(1);
  startTime.value = '0';
  startTime.max = video.duration;
  endTime.max = video.duration;
});

// Corte
video.addEventListener('timeupdate',()=>{
  const s = parseFloat(startTime.value)||0;
  const e = parseFloat(endTime.value)||video.duration||0;
  if(video.currentTime < s || video.currentTime > e+0.05){
    if(video.currentTime > e && !video.paused){
      video.currentTime = s;
    }
  }
  // legendas
  if(burnToggle.checked && subtitles.length){
    const t = video.currentTime;
    const sub = subtitles.find(x=>t>=x.start && t<=x.end);
    if(sub){subtitleOverlay.textContent=sub.text;subtitleOverlay.style.display='block'}
    else{subtitleOverlay.style.display='none'}
  }
});
document.getElementById('markStart').onclick=()=>{if(video.duration)startTime.value=video.currentTime.toFixed(1)};
document.getElementById('markEnd').onclick=()=>{if(video.duration)endTime.value=video.currentTime.toFixed(1)};
document.getElementById('resetCut').onclick=()=>{startTime.value=0;endTime.value=video.duration?video.duration.toFixed(1):0};

// Filtros
function updateFilters(){
  video.style.filter = `brightness(${brightness.value}%) contrast(${contrast.value}%) saturate(${saturation.value}%)`;
  bVal.textContent = brightness.value+'%';
  cVal.textContent = contrast.value+'%';
  sVal.textContent = saturation.value+'%';
}
[brightness,contrast,saturation].forEach(s=>s.addEventListener('input',updateFilters));
document.querySelectorAll('.preset-btn[data-b]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    brightness.value=btn.dataset.b;
    contrast.value=btn.dataset.c;
    saturation.value=btn.dataset.s;
    updateFilters();
  });
});
updateFilters();

// Legendas
function parseSRT(text){
  const entries=[];
  const blocks=text.trim().split(/\n\s*\n/);
  for(const block of blocks){
    const lines=block.split('\n');
    if(lines.length>=2){
      const m=lines[1].match(/(\d{2}):(\d{2}):(\d{2}),(\d{3})\s*-->\s*(\d{2}):(\d{2}):(\d{2}),(\d{3})/);
      if(m){
        const start=(+m[1])*3600+(+m[2])*60+(+m[3])+(+m[4])/1000;
        const end=(+m[5])*3600+(+m[6])*60+(+m[7])+(+m[8])/1000;
        const txt=lines.slice(2).join('\n');
        entries.push({start,end,text:txt});
      }
    }
  }
  return entries;
}
srtInput.addEventListener('input',()=>{subtitles=parseSRT(srtInput.value)});
burnToggle.addEventListener('change',()=>{subtitleOverlay.style.display=burnToggle.checked?'block':'none';if(!burnToggle.checked)subtitleOverlay.textContent=''});

// Pro
function updateProUI(){
  proStatus.textContent = isPro ? 'PRO ATIVO' : 'Grátis';
  proStatus.className = 'status ' + (isPro?'pro':'free');
  document.querySelectorAll('.pro-feature').forEach(el=>{
    const icon=el.querySelector('.icon');
    if(isPro){el.classList.add('unlocked');icon.textContent='✓'}
    else{el.classList.remove('unlocked');icon.textContent='🔒'}
  });
  if(isPro){
    res4k.disabled=false;
    card4k.classList.remove('locked');
  }else{
    res4k.disabled=true;
    card4k.classList.add('locked');
    if(res4k.checked)res1080.checked=true;
    updateRadioCards();
  }
}
activateBtn.onclick=()=>{
  const code=codeInput.value.trim().toUpperCase();
  if(PRO_CODES.includes(code)){
    isPro=true;
    localStorage.setItem('vazacut_pro','true');
    updateProUI();
    showToast('Código ativado! Bem-vindo ao PRO.');
    codeInput.value='';
  }else{
    showToast('Código inválido',true);
  }
};
updateProUI();

// Export radios visual
function updateRadioCards(){
  document.querySelectorAll('.radio-card').forEach(c=>{
    c.classList.toggle('active', c.querySelector('input').checked);
  });
}
document.querySelectorAll('input[name="res"]').forEach(r=>r.addEventListener('change',updateRadioCards));
updateRadioCards();

// Export simulation
exportBtn.onclick=()=>{
  if(!video.src){showToast('Escolha um vídeo primeiro',true);return;}
  const res=document.querySelector('input[name="res"]:checked').value;
  if(res==='4k' && !isPro){showToast('4K é recurso PRO. Ative na aba Pro.',true);document.querySelector('[data-tab="pro"]').click();return;}
  
  exportBtn.disabled=true;
  progressWrap.style.display='block';
  progressFill.style.width='0%';
  
  const s=parseFloat(startTime.value)||0;
  const e=parseFloat(endTime.value)||video.duration||0;
  const hasSub=burnToggle.checked && subtitles.length>0;
  const filt = `b${brightness.value} c${contrast.value} s${saturation.value}`;
  
  let p=0;
  const timer=setInterval(()=>{
    p+=Math.random()*14;
    if(p>=100){p=100;clearInterval(timer);
      progressFill.style.width='100%';
      progressText.textContent=`Concluído! • ${res.toUpperCase()} • Corte ${s.toFixed(1)}s-${e.toFixed(1)}s`;
      setTimeout(()=>{
        exportBtn.disabled=false;
        progressWrap.style.display='none';
        showToast('Exportação simulada concluída! (render real 100% local em breve)');
      },900);
    }else{
      progressFill.style.width=p+'%';
      progressText.textContent=`Renderizando... ${Math.floor(p)}% • ${res.toUpperCase()} • ${hasSub?'legenda':'sem legenda'} • ${filt}`;
    }
  },160);
};

// Toast
const toast=document.getElementById('toast');
let toastTimer;
function showToast(msg,isErr){
  toast.textContent=msg;
  toast.className='toast show'+(isErr?' error':'');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>toast.classList.remove('show'),3000);
}

// Demo subtitle
srtInput.dispatchEvent(new Event('input'));
</script>
